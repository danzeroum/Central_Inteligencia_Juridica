# Variáveis de ambiente — Central de Inteligência Jurídica
# Copie para `.env` e ajuste conforme necessário. Todas têm padrões sensatos;
# o sistema funciona sem nenhuma chave (usa fallbacks/mock).

# ===== Geral =====
ENVIRONMENT=development            # development | production | test

# ===== LLM (classificação de intenção / análises) =====
# Sem OPENAI_API_KEY, a classificação usa um fallback heurístico determinístico.
OPENAI_API_KEY=
OLLAMA_MODEL=llama3               # modelo local para análises legislativas

# ===== Segurança =====
# OBRIGATÓRIO fora de ENVIRONMENT=test (mínimo 32 caracteres). A ausência impede
# o boot da aplicação (fail-fast) — não é opcional em produção.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Exige JWT nos endpoints. Padrão: true (false apenas quando ENVIRONMENT=test).
AUTH_REQUIRED=true
# Timeout de sessão JWT (BACEN 4.658). Padrão 30 min; operações privilegiadas
# (admin/operator/auditor) usam um timeout mais curto (15 min) via issue_token.
JWT_EXPIRY_MINUTES=30
JWT_PRIVILEGED_EXPIRY_MINUTES=15
# Limite de requisições por IP por minuto (rate limiting).
RATE_LIMIT_PER_MINUTE=60

# ===== Redis (cache + canal A2A + estado compartilhado) =====
# OBRIGATÓRIO no docker compose (Redis sobe com --requirepass). Em dev local sem
# Redis, há fallback in-memory.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Alternativa única: REDIS_URL=redis://:senha@localhost:6379/0

# ===== Cloud-readiness: backends de estado compartilhado =====
# Padrão = single-node (Docker). Ao escalar horizontalmente (múltiplas réplicas),
# mude para 'redis' para que rate limit, trilha de auditoria e fila HITL sejam
# compartilhados entre réplicas. Sem isto, cada réplica teria estado isolado.
RATE_LIMIT_BACKEND=memory         # memory | redis
LEDGER_BACKEND=file               # file | redis
HITL_BACKEND=memory               # memory | redis

# ===== Observabilidade =====
# Formato de log: json (recomendado em produção, p/ agregadores) | text (dev).
LOG_FORMAT=text
LOG_LEVEL=INFO
SERVICE_NAME=central-inteligencia-juridica
# Tracing distribuído (OPCIONAL). Vazio = desativado (no-op). Para habilitar
# localmente: docker compose --profile tracing up e use:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# ===== Segurança de transporte (cabeçalhos) =====
# Habilite o HSTS apenas quando houver TLS terminado à frente (proxy/ingress).
ENABLE_HSTS=false

# ===== Cifragem do cache em repouso (OPCIONAL) =====
# Quando true, valores sensíveis no Redis são cifrados com Fernet. A chave vem do
# KeyProvider (env hoje; KMS/Vault no futuro — ver src/utils/key_provider.py).
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CACHE_ENCRYPTION_ENABLED=false
CACHE_ENCRYPTION_KEY=
KEY_PROVIDER=env                  # env (futuro: kms | vault)

# ===== Memória vetorial (ChromaDB) — opcional =====
VECTOR_MEMORY_MODE=local          # local | remote
VECTOR_MEMORY_PERSIST_PATH=.vector_memory

# ===== APIs reais de tribunais — opcional (sem token, usa dados mock) =====
TJSP_API_TOKEN=
TJMG_API_KEY=

# ===== Circuit Breaker =====
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# ===== Monitoramento (Grafana) =====
# A senha é obrigatória para subir o serviço grafana via docker compose.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
