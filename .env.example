# Environment variables for Central Inteligência Jurídica

# Real APIs (Onda 2.3)
# TJSP - São Paulo
TJSP_API_TOKEN=your_bearer_token_here

# TJMG - Minas Gerais
TJMG_API_KEY=your_api_key_here

# Circuit Breaker Settings
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# Redis - configurações para agentes assíncronos
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama - modelo local para análises legislativas
OLLAMA_MODEL=llama3
