# Variáveis de ambiente — Central de Inteligência Jurídica
# Copie para `.env` e ajuste conforme necessário. Todas têm padrões sensatos;
# o sistema funciona sem nenhuma chave (usa fallbacks/mock).

# ===== Geral =====
ENVIRONMENT=development            # development | production | test

# ===== LLM (classificação de intenção / análises) =====
# Sem OPENAI_API_KEY, a classificação usa um fallback heurístico determinístico.
OPENAI_API_KEY=
OLLAMA_MODEL=llama3               # modelo local para análises legislativas

# ===== Segurança =====
# OBRIGATÓRIO fora de ENVIRONMENT=test (mínimo 32 caracteres). A ausência impede
# o boot da aplicação (fail-fast) — não é opcional em produção.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Exige JWT nos endpoints. Padrão: true (false apenas quando ENVIRONMENT=test).
AUTH_REQUIRED=true
# Limite de requisições por IP por minuto (rate limiting).
RATE_LIMIT_PER_MINUTE=60

# ===== Redis (cache + canal A2A) — opcional, há fallback in-memory =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Alternativa única: REDIS_URL=redis://localhost:6379/0

# ===== Memória vetorial (ChromaDB) — opcional =====
VECTOR_MEMORY_MODE=local          # local | remote
VECTOR_MEMORY_PERSIST_PATH=.vector_memory

# ===== APIs reais de tribunais — opcional (sem token, usa dados mock) =====
TJSP_API_TOKEN=
TJMG_API_KEY=

# ===== Circuit Breaker =====
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# ===== Monitoramento (Grafana) =====
# A senha é obrigatória para subir o serviço grafana via docker compose.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
