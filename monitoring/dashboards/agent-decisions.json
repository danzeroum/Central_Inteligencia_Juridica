{
  "dashboard": {
    "title": "Agent Decision Intelligence",
    "tags": ["cij", "agents", "decisions"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Decision Rate by Agent",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(agent_decisions_total[5m])",
            "legendFormat": "{{agent}} - {{decision_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Decisions/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Decision Confidence Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(agent_decision_confidence_bucket[5m])",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "dataFormat": "tsbuckets",
        "yAxis": {"format": "short", "decimals": 1}
      },
      {
        "id": 3,
        "title": "Consensus Strength Over Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.5, rate(consensus_strength_bucket[5m]))",
            "legendFormat": "P50 Consensus Strength",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(consensus_strength_bucket[5m]))",
            "legendFormat": "P95 Consensus Strength",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "Strength", "min": 0, "max": 1},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [0.6], "type": "lt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "Low Consensus Strength Alert",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 4,
        "title": "HITL Queue Depth",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "hitl_queue_depth",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 3},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "HITL Response Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(hitl_response_time_seconds_bucket[5m]))",
            "legendFormat": "P95 Response Time",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Time"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "Agent Autonomy Levels",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "agent_autonomy_level",
            "legendFormat": "{{agent}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 5,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 2},
                {"color": "green", "value": 4}
              ]
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        }
      },
      {
        "id": 7,
        "title": "Agent Trust Scores",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "agent_trust_score",
            "legendFormat": "{{agent}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 1,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.5},
                {"color": "green", "value": 0.8}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Pattern Activation Frequency",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "sum by (pattern) (rate(pattern_activation_total[1h]))",
            "legendFormat": "{{pattern}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Pattern Failure Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
        "targets": [
          {
            "expr": "rate(pattern_failure_total[5m])",
            "legendFormat": "{{pattern}} - {{failure_reason}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Failures/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Fallback Triggers",
        "type": "table",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
        "targets": [
          {
            "expr": "sum by (from_pattern, to_pattern, reason) (increase(fallback_triggers_total[1h]))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "from_pattern": "From",
                "to_pattern": "To",
                "reason": "Reason",
                "Value": "Count"
              }
            }
          }
        ]
      },
      {
        "id": 11,
        "title": "Decision Success Rate by Agent",
        "type": "stat",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "sum by (agent) (rate(agent_decisions_total{outcome=\"success\"}[5m])) / sum by (agent) (rate(agent_decisions_total[5m]))",
            "legendFormat": "{{agent}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "green", "value": 0.9}
              ]
            }
          }
        },
        "options": {
          "orientation": "auto",
          "textMode": "value_and_name",
          "colorMode": "background"
        }
      }
    ],
    "refresh": "10s",
    "schemaVersion": 36,
    "version": 1
  }
}
