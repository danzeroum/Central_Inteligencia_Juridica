{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalVersion": 2,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Escriturações Processadas (total)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "targets": [{"expr": "sum(fiscal_escrituracoes_processadas_total)", "legendFormat": "Total", "refId": "A"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Apurações Realizadas (total)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "sum(fiscal_apuracoes_realizadas_total)", "legendFormat": "Total", "refId": "A"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Achados — Erros",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 1}]}}},
      "targets": [{"expr": "sum(fiscal_achados_registrados_total{severidade=\"erro\"})", "legendFormat": "Erros", "refId": "A"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Retificações Geradas",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "targets": [{"expr": "sum(fiscal_retificacoes_geradas_total)", "legendFormat": "Retificações", "refId": "A"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Escriturações processadas (taxa/min)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "targets": [
        {"expr": "rate(fiscal_escrituracoes_processadas_total{status=\"processado\"}[5m])*60", "legendFormat": "processado", "refId": "A"},
        {"expr": "rate(fiscal_escrituracoes_processadas_total{status=\"erro\"}[5m])*60", "legendFormat": "erro", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Apurações por Situação",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"pieType": "donut", "tooltip": {"mode": "single"}, "legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "sum by (situacao) (fiscal_apuracoes_realizadas_total)", "legendFormat": "{{situacao}}", "refId": "A"}
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Achados por Regra (top N)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"orientation": "horizontal", "legend": {"displayMode": "list"}},
      "targets": [
        {"expr": "topk(10, sum by (regra_id) (fiscal_achados_registrados_total))", "legendFormat": "{{regra_id}}", "refId": "A"}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Saldo apurado (abs, histograma p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, tributo) (rate(fiscal_saldo_apurado_abs_bucket[10m])))", "legendFormat": "p95 {{tributo}}", "refId": "A"},
        {"expr": "histogram_quantile(0.50, sum by (le, tributo) (rate(fiscal_saldo_apurado_abs_bucket[10m])))", "legendFormat": "p50 {{tributo}}", "refId": "B"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["fiscal", "auditoria", "onda2"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Auditoria Fiscal — Pipeline SPED (S-E.1)",
  "uid": "fiscal-auditoria-se1",
  "version": 1
}
