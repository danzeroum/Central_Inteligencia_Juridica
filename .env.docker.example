# =============================================================================
# Preset TURNKEY — "tudo em Docker, modo REAL, pronto para escalar".
# Copie para `.env` e ajuste as senhas (TROQUE_*). Depois:
#
#   docker network create btv-prod-net        # rede externa exigida pelo compose
#   cp .env.docker.example .env                # e edite as senhas
#   docker compose --profile migrate run --rm migrate   # cria as tabelas
#   docker compose -f docker-compose.yml -f docker-compose.local.yml \
#       --profile chromadb --profile storage --profile workers --profile llm up -d
#   docker compose exec ollama ollama pull llama3        # baixa o modelo de IA
#
# App em http://localhost:8000/app (o override local publica a porta 8000).
# =============================================================================

# --- Segurança (OBRIGATÓRIO) -------------------------------------------------
# Gere o segredo: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=TROQUE_POR_UM_TOKEN_DE_NO_MINIMO_48_CARACTERES_ALEATORIOS
AUTH_REQUIRED=true
REDIS_PASSWORD=TROQUE_ESTA_SENHA_REDIS
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_POSTGRES
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=TROQUE_ESTA_SENHA_GRAFANA

# --- Persistência relacional (Postgres em Docker) ----------------------------
# Tira o pipeline fiscal/analytics do modo "stub (sem DATABASE_URL)".
# O app normaliza para asyncpg; o alembic usa a forma síncrona — a mesma URL serve.
DATABASE_URL=postgresql://cij:TROQUE_ESTA_SENHA_POSTGRES@postgres:5432/cij

# --- Estado compartilhado p/ ESCALA horizontal (Redis) -----------------------
# Com estes backends em 'redis', várias réplicas do app compartilham
# rate-limit, ledger e fila HITL (multi-réplica consistente).
RATE_LIMIT_BACKEND=redis
LEDGER_BACKEND=redis
HITL_BACKEND=redis

# --- Memória vetorial / RAG (ChromaDB em Docker, --profile chromadb) ----------
VECTOR_MEMORY_MODE=remote
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- Armazenamento de documentos (MinIO em Docker, --profile storage) ---------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=TROQUE_ESTA_SENHA_MINIO
MINIO_BUCKET=cij-documents
MINIO_USE_SSL=false

# --- Jobs assíncronos (Celery + Redis broker, --profile workers) --------------
CELERY_BROKER_URL=redis://:TROQUE_ESTA_SENHA_REDIS@redis:6379/0
CELERY_RESULT_BACKEND=redis://:TROQUE_ESTA_SENHA_REDIS@redis:6379/1

# --- IA local (Ollama em Docker, --profile llm) ------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
# Liga o Chain-of-Thought por LLM no ArchitectAgent (degrada p/ heurística).
ARCHITECT_COT_LLM=1

# --- Integrações jurídicas reais ---------------------------------------------
# As fontes implementadas (DataJud/DJEN/Receita/TSE) já vêm =real por padrão e
# degradam para mock sem chave. Forneça a chave do DataJud p/ jurisprudência real:
DATAJUD_API_KEY=
INTEGRATIONS_DATAJUD_API_KEY=

# --- Observabilidade ---------------------------------------------------------
LOG_FORMAT=json
ENVIRONMENT=production
